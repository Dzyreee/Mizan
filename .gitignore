# ---- Secrets (NEVER commit) ----
.env
.env.*
!.env.example
*.key

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node / Next.js ----
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-error.log*

# ---- Generated artifacts ----
*.pdf
*.png
*.wav
*.mp3
backend/smoke/_out/
backend/eval/_out/
!docs/**/*.png
# UI assets are part of the app — keep them in the repo (mascot art + illustration library).
!frontend/public/**/*.png

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
*.swp

# Playwright MCP artifacts
.playwright-mcp/

# Local Claude Code skills (not shared)
.claude/skills/

# ---- Per-child profiles (runtime data), keep only the committed demo sample ----
backend/data/profiles/*.json
!backend/data/profiles/demo-child.json
